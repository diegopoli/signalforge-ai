<h1 class="mb-6 text-2xl font-semibold">Dashboard</h1>

<div class="grid gap-4 md:grid-cols-3">
  <div class="rounded-xl border border-slate-200 bg-white p-5">
    <p class="text-sm text-slate-500">Clients</p>
    <p class="mt-2 text-3xl font-semibold"><%= @clients_count %></p>
  </div>
  <div class="rounded-xl border border-slate-200 bg-white p-5">
    <p class="text-sm text-slate-500">Notes Processed</p>
    <p class="mt-2 text-3xl font-semibold"><%= @notes_count %></p>
  </div>
  <div class="rounded-xl border border-slate-200 bg-white p-5">
    <p class="text-sm text-slate-500">Documents</p>
    <p class="mt-2 text-3xl font-semibold"><%= @documents_count %></p>
  </div>
</div>

<section class="mt-8 rounded-xl border border-slate-200 bg-white p-5">
  <h2 class="mb-4 text-lg font-semibold">Recent AI Activity</h2>
  <% if @recent_logs.any? %>
    <ul class="space-y-3">
      <% @recent_logs.each do |log| %>
        <li class="rounded-lg border border-slate-100 bg-slate-50 p-3">
          <p class="text-sm font-medium"><%= log.log_type.humanize %></p>
          <p class="text-sm text-slate-600"><%= log.content %></p>
          <p class="mt-1 text-xs text-slate-500"><%= log.created_at.strftime("%b %d, %Y %H:%M") %></p>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-slate-500">No activity yet. Add a client and upload a note to trigger AI workflows.</p>
  <% end %>
</section>
