<section class="relative overflow-hidden rounded-3xl border border-slate-200 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-700 px-8 py-16 text-white">
  <div class="absolute -right-20 -top-20 h-60 w-60 rounded-full bg-cyan-400/20 blur-3xl"></div>
  <div class="absolute -left-10 bottom-0 h-48 w-48 rounded-full bg-emerald-300/20 blur-3xl"></div>
  <div class="relative mx-auto max-w-3xl text-center">
    <p class="mb-3 text-sm uppercase tracking-[0.2em] text-cyan-200">AI-native CRM workflow automation</p>
    <h1 class="text-4xl font-semibold leading-tight md:text-5xl">SignalForge AI for financial advisor operations</h1>
    <p class="mt-5 text-base text-slate-200 md:text-lg">
      Summarize meetings, extract action items, draft follow-up emails, and search advisor knowledge with RAG.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <%= link_to "Start free demo", new_user_registration_path, class: "rounded-xl bg-white px-5 py-3 text-sm font-semibold text-slate-900" %>
      <%= link_to "Sign in", new_user_session_path, class: "rounded-xl border border-white/30 px-5 py-3 text-sm font-semibold text-white" %>
    </div>
  </div>
</section>
