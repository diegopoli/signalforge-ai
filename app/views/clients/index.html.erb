<div class="mb-6 flex items-center justify-between">
  <h1 class="text-2xl font-semibold">Clients</h1>
  <%= link_to "New Client", new_client_path, class: "rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white" %>
</div>

<div class="space-y-3">
  <% @clients.each do |client| %>
    <a href="<%= client_path(client) %>" class="block rounded-xl border border-slate-200 bg-white p-4 transition hover:border-slate-300">
      <div class="flex items-center justify-between">
        <div>
          <p class="font-semibold"><%= client.full_name %></p>
          <p class="text-sm text-slate-500"><%= client.email %></p>
        </div>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600"><%= client.lifecycle_stage %></span>
      </div>
    </a>
  <% end %>

  <% if @clients.empty? %>
    <div class="rounded-xl border border-dashed border-slate-300 bg-white p-8 text-center text-sm text-slate-500">
      No clients yet. Add your first client.
    </div>
  <% end %>
</div>
