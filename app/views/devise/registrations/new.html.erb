<div class="mx-auto max-w-md rounded-xl border border-slate-200 bg-white p-6">
  <h1 class="mb-4 text-xl font-semibold">Create account</h1>
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <div>
      <%= f.label :email, class: "mb-1 block text-sm font-medium" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= f.label :password, class: "mb-1 block text-sm font-medium" %>
      <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= f.label :password_confirmation, class: "mb-1 block text-sm font-medium" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-lg border border-slate-300 px-3 py-2" %>
    </div>
    <%= f.submit "Create account", class: "w-full rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white" %>
  <% end %>
  <p class="mt-4 text-sm text-slate-600">Already registered? <%= link_to "Sign in", new_session_path(resource_name), class: "font-medium text-slate-900" %></p>
</div>
